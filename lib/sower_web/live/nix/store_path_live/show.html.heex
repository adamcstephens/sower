<.header>
  {@store_path.path}
</.header>

<.list>
  <:item title="inserted">{@store_path.inserted_at}</:item>
  <:item title="updated">{@store_path.updated_at}</:item>

  <:item title="seeds">
    <.table
      id="seeds"
      rows={@store_path.seeds}
      row_click={fn seed -> JS.navigate(~p"/seeds/#{seed}") end}
    >
      <:col :let={seed}>{seed.name}</:col>
    </.table>
  </:item>
</.list>

<.back navigate={~p"/nix/store_paths"}>Back to store_paths</.back>
