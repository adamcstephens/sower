#!/usr/bin/env nix-shell
#!nix-shell -i nu -p postgresql

let runtimedir = $"($env.XDG_RUNTIME_DIR)/postgres"

let config = "log_connections = yes
log_statement = 'all'
logging_collector = yes
log_disconnections = yes
log_destination = 'stderr'"

mkdir ./_build/data/postgres
chmod 700 ./_build/data/postgres
mkdir $runtimedir

$config | save --force ./_build/data/postgres/postgresql.conf
if (("./_build/data/postgres/data" | path exists) != true) {
  initdb -U postgres ./_build/data/postgres/data
}

postgres -D ./_build/data/postgres/data -k $runtimedir
