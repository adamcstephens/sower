#!/usr/bin/env nu

def attic-setup [url: string, cache: string, token: string] {
  try {
    attic cache info $"main:($cache)"
  } catch {
    print $"⭐ Adding attic cache"
    attic login main $url --set-default $token
  }
  attic cache info $"main:($cache)"
}

def attic-use [cache: string] {
  attic use $"main:($cache)"
}

export def attic-upload [cache: string] {
  let paths = $in

  if ($paths  | length) == 0 {
    print "‼️ No targets to push to attic. Skipping push"
  } else {
    print $"📤 Pushing to attic cache ($cache)"
    attic push --ignore-upstream-cache-filter --jobs 10 $"main:($cache)" ...$paths
  }
}

export def load-seeds [] {
  nix eval .#sower --json | from json | transpose type targets | each {|type| $type | update targets ($type.targets | transpose name config) }
}

export def filter-configs [--system: string] {
  let configs = $in

  if $system == null {
    $configs
  } else {
    $configs | each { |c|
      $c | update targets (
        $c.targets | filter { |i|
          $system in $i.config.systems
        } | each { |i|
          $i | update config.systems [$system]
        }
      )
    }
  }
}

export def build-configs [] {
  let configs = $in

  $configs | each { |c|
    $c | update targets ($c.targets | par-each --threads 4 { |i|
      let buildTarget = if $c.type == "darwin" {
        $".#darwinConfigurations.($i.name).system"
      } else if $c.type == "dev-shell" {
        $i.config.systems | each {|t| $".#devShells.($t).($i.name)" }
      } else if $c.type == "home-manager" {
        $".#homeConfigurations.($i.name).activationPackage"
      } else if $c.type == "nixos" {
        $".#nixosConfigurations.($i.name).config.system.build.toplevel"
      } else if $c.type == "package" {
        $i.config.systems | each {|t| $".#packages.($t).($i.name)" }
      } else {
        print $"!! Unsupported type ($c.type)"
        exit 1
      }

      let result = try {
        nix build --no-link --fallback --keep-going --json ...$buildTarget | from json
      } catch {
        null
      }

      $i | insert build $result
    })
  }
}

export def upload-configs [--attic-cache: string = "default"] {
  let configs = $in

  $configs | reduce --fold [] { |c, acc|
    $acc ++ ($c.targets | filter { |t| $t.build != null } | get build | flatten | get outputs.out)
  } | attic-upload $attic_cache

  $configs
}

export def get-config-failures [] {
  let configs = $in

  $configs | filter { |c|
    # filter top-levels down to failed ones
    $c.targets | any { |t|
      $t.build == null
    }
  } | each { |c|
    # filter targets down to failed ones
    $c | update targets ($c.targets | filter { |t|
      $t.build == null
    })
  } | each { |c|
    # simplify for output
    $c.targets | each { |t|
      { type: $c.type, name: $t.name }
    }
  } | flatten
}

export def get-config-outputs [] {
  let configs = $in

  $configs | each { |c|
    # simplify for output
    $c.targets | filter { |t| $t.build != null } | each { |t|
      { type: $c.type, name: $t.name, output: $t.build.outputs.out.0 }
    }
  } | flatten
}

export def gen-targets [--system: string] {
  try { rm -r gcroot/* }
  let eval_args = [
    "--gc-roots-dir", "gcroot",
  ] ++ (if $env.NIX_EVAL_ARGS? != null {
    # dirty, but 🤷
    $env.NIX_EVAL_ARGS | split row " "
  } else { [ ] })

  ['.#devShells', '.#packages'] | each {|target|
    nix eval $target --apply builtins.attrNames --json | from json | each { |sys|
      if $system != null and $system != $sys { continue }
      print $"🛗 Evaluating ($target).($sys)"

      nix-eval-jobs --workers 12 --flake $"($target).($sys)" $eval_args | lines | each {|l|
        $l | from json | select name drvPath
      }
    } | flatten
  } | flatten
}

def main [--attic-upload = true, --attic-use = false, --eval-only, --nom = true, --system: string] {
  let attic_url = $env.ATTIC_URL?
  let attic_cache = $env.ATTIC_CACHE?
  let attic_token = $env.ATTIC_KEY?

  if $attic_use or $attic_upload {
    if ($attic_url == null) or ($attic_cache == null) or ($attic_token == null)) {
      print "‼️ attic information missing, but attic-use or attic-upload are set to true"
      exit 1
    }

    attic-setup $attic_url $attic_cache $attic_token

    if $attic_use {
      attic-use $attic_cache
    }
  }

  let seeds = load-seeds | filter-configs --system $system
  let built_seeds = $seeds | build-configs

  if $attic_upload {
    $built_seeds | upload-configs --attic-cache $attic_cache
  }

  print "🎯 Built seeds"
  print ($built_seeds | get-config-outputs)

  if ($built_seeds | any { |c| $c.targets | any { |t| $t.build == null } }) {
    print "💀 Failed targets"
    print ($built_seeds | get-config-failures)
    exit 1
  } else {
    print "🥳 Success!"
  }
}
