#!/usr/bin/env nu

def attic-setup [url: string, cache: string, token: string] {
  print $"⭐ Ensuring attic cache ($url)/($cache)"
  let check = attic cache info $"main:($cache)" | complete

  if $check.exit_code != 0 {
    attic login main $url --set-default $token
  }

  attic cache info $"main:($cache)"
}

def attic-use [cache: string] {
  attic use $"main:($cache)"
}

export def attic-upload [cache: string] {
  let paths = $in

  if ($paths  | length) == 0 {
    print "‼️ No targets to push to attic. Skipping push"
  } else {
    print $"📤 Pushing to attic cache ($cache)"
    $paths | str join "\n" | xargs attic push --ignore-upstream-cache-filter --jobs 10 $"main:($cache)"
  }
}

export def load-seeds [] {
  nix eval .#sower --json | from json | transpose seed_type targets | each {|seed_type| $seed_type | update targets ($seed_type.targets | transpose name config) }
}

export def filter-configs [--system: string] {
  let configs = $in

  if $system == null {
    $configs
  } else {
    $configs | each { |c|
      $c | update targets (
        $c.targets | filter { |i|
          $system in $i.config.systems
        } | each { |i|
          $i | update config.systems [$system]
        }
      )
    }
  }
}

export def build-configs [--threads: int] {
  let configs = $in

  print $"Building configs with ($threads) threads"

  $configs | each { |c|
    $c | update targets ($c.targets | par-each --threads $threads { |i|
      let buildTarget: list<string> = if $c.seed_type == "nix-darwin" {
        [$".#darwinConfigurations.($i.name).system"]
      } else if $c.seed_type == "dev-shell" {
        $i.config.systems | each {|t| $".#devShells.($t).($i.name)" }
      } else if $c.seed_type == "home-manager" {
        [$".#homeConfigurations.($i.name).activationPackage"]
      } else if $c.seed_type == "nixos" {
        [$".#nixosConfigurations.($i.name).config.system.build.toplevel"]
      } else if $c.seed_type == "package" {
        $i.config.systems | each {|t| $".#packages.($t).($i.name)" }
      } else {
        print $"!! Unsupported type ($c.seed_type)"
        exit 1
      }

      let result = try {
        nix build --no-link --fallback --keep-going --json ...$buildTarget | from json
      } catch {
        null
      }

      $i | insert build $result
    })
  }
}

export def upload-configs [--attic-cache: string, --cache-build-deps = false, --cache-inputs = false] {
  let configs = $in

  $configs | reduce --fold [] { |c, acc|
    let built_targets = $c.targets | filter { |t| $t.build != null } | get build | flatten
    let build_dependencies = if $cache_build_deps {
      $built_targets | get drvPath | each { |drv|
        nix-store --query --requisites --include-outputs $drv | lines
      } | flatten
    } else { [] }
    let inputs = if $cache_inputs {  get-flake-inputs | get outPath } else { [] }
    $acc ++ ( $built_targets | get outputs.out ) ++ $build_dependencies ++ $inputs
  } | attic-upload $attic_cache

  $configs
}

export def get-config-failures [] {
  let configs = $in

  $configs | filter { |c|
    # filter top-levels down to failed ones
    $c.targets | any { |t|
      $t.build == null
    }
  } | each { |c|
    # filter targets down to failed ones
    $c | update targets ($c.targets | filter { |t|
      $t.build == null
    })
  } | each { |c|
    # simplify for output
    $c.targets | each { |t|
      { seed_type: $c.seed_type, name: $t.name }
    }
  } | flatten
}

export def get-config-outputs [] {
  let configs = $in

  $configs | each { |c|
    # simplify for output
    $c.targets | filter { |t| $t.build != null } | each { |t|
      { seed_type: $c.seed_type, name: $t.name, store_path: $t.build.outputs.out.0 }
    }
  } | flatten
}

export def get-flake-inputs [] {
  nix flake archive --json | from json | get inputs | transpose | select column0 column1.path | each { |c|
    {
      name: $c.column0,
      outPath: $c."column1.path",
      drvPath: nul
    }
  }
}

export def post-sower-seeds [--sower-url: string] {
  let configs = $in
  print $"🫱 Giving seeds to sower ($sower_url)"

  let git_branch = get-git-branch
  let repo_url = get-repo-url

  # sower only understands certain build outputs
  $configs | filter { |c| $c.seed_type == "home-manager" or $c.seed_type == "nix-darwin" or $c.seed_type == "nixos" } | each { |c|
    $c.targets | filter { |t| $t.build != null } | each { |t|
      let seed = {
        name: $t.name,
        seed_seed_type: $c.seed_type,
        store_path: $t.build.outputs.out.0,,
        branch: $git_branch,
        repo_url: $repo_url
      }

      http post --content-type application/json $"($sower_url)/api/seeds" $seed
    }
  }
}

export def get-git-branch [] {
  if $env.CI_COMMIT_SOURCE_BRANCH? != null {
    $env.CI_COMMIT_SOURCE_BRANCH
  } else if $env.CI_COMMIT_BRANCH? != null {
    $env.CI_COMMIT_BRANCH
  } else if $env.GITHUB_HEAD_REF? != null {
    $env.GITHUB_HEAD_REF
  } else if $env.GITHUB_REF_NAME? != null {
    $env.GITHUB_REF_NAME
  } else if (".git" | path exists) {
    let dirty = if ((git diff-index --quiet HEAD -- | complete | get exit_code) == 0) { "" } else { "-" + (git rev-parse --short HEAD) + "-dirty" }
    $"(git rev-parse --abbrev-ref HEAD)($dirty)"
  } else {
    null
  }
}

export def get-repo-url [] {
  if $env.CI_REPO_URL? != null {
    $env.CI_REPO_URL
  } else if $env.GITHUB_REPOSITORY? != null {
    $env.GITHUB_REPOSITORY
  } else if (".git" | path exists) {
    git remote get-url origin
  } else {
    null
  }
}

def main [
  --attic-upload = true,
  --attic-use = false,
  --cache-build-deps = false,
  --cache-inputs = true,
  --eval-only,
  --nom = true,
  --sower-seed = false,
  --system: string,
  --threads: int = 8
  ] {
  let attic_url = $env.ATTIC_URL?
  let attic_cache = $env.ATTIC_CACHE?
  let attic_token = $env.ATTIC_KEY?

  if $attic_use or $attic_upload {
    if ($attic_url == null) or ($attic_cache == null) or ($attic_token == null) {
      print "‼️ attic information missing, but attic-use or attic-upload are set to true"
      exit 1
    }

    attic-setup $attic_url $attic_cache $attic_token

    if $attic_use {
      attic-use $attic_cache
    }
  }

  let seeds = load-seeds | filter-configs --system $system
  let built_seeds = $seeds | build-configs --threads $threads

  if $attic_upload {
    $built_seeds | upload-configs --attic-cache $attic_cache --cache-build-deps $cache_build_deps --cache-inputs $cache_inputs
  }

  if $sower_seed {
    let sower_url = $env.SOWER_URL?
    if $sower_url == null {
      print "‼️ sower url missing, but sower seed set to true"
      exit 1
    }
    $built_seeds | post-sower-seeds --sower-url $sower_url
  }

  print "🎯 Built seeds"
  print ($built_seeds | get-config-outputs)

  if ($built_seeds | any { |c| $c.targets | any { |t| $t.build == null } }) {
    print "💀 Failed targets"
    print ($built_seeds | get-config-failures)
    exit 1
  } else {
    print "🥳 Success!"
  }
}
