use flake

dotenv_if_exists .secret.envrc

genSecret() {
  SECRET="$1"
  if [ ! -f "$SECRET" ]; then
    echo "Creating development cookie file"
    dd if=/dev/urandom bs=1 count=64 | hexdump -e '64/1 "%02x"' >"$SECRET"
  fi
}

export SOWER_SERVER_CONFIG_FILE="$PWD/dev-server.json"

RELEASE_COOKIE_FILE="$PWD/.dev-cookie"
genSecret "$RELEASE_COOKIE_FILE"
RELEASE_COOKIE=$(cat "$RELEASE_COOKIE_FILE")
export RELEASE_COOKIE

genSecret "$SOWER_SECRET_KEY_BASE_FILE"

export SOWER_BOOTSTRAP_TOKEN_FILE="$PWD/.bootstrap.token"
genSecret "$SOWER_BOOTSTRAP_TOKEN_FILE"

export ERL_AFLAGS="-kernel shell_history enabled -kernel shell_history_file_bytes 1024000"
