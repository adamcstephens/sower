{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "dap-sower-seed",
      "program": "${workspaceFolder}/target/debug/sower",
      "args": [
        "seed",
        "download",
        "--url=http://localhost:4000",
        "--bootstrap-token-file=${workspaceFolder}/.bootstrap.token"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug executable 'sower'",
      "cargo": {
        "args": ["build", "--bin=sower", "--package=sower"],
        "filter": {
          "name": "sower",
          "kind": "bin"
        }
      },
      "args": [
        "seed",
        "download",
        "--url=http://localhost:4000",
        "--bootstrap-token-file=${workspaceFolder}/.bootstrap.token"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug unit tests in executable 'sower'",
      "cargo": {
        "args": ["test", "--no-run", "--bin=sower", "--package=sower"],
        "filter": {
          "name": "sower",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}"
    }
  ]
}
