<Layouts.app flash={@flash} current_user={@current_user} nav_section={assigns[:nav_section]}>
  <.header>
    <div class="flex items-center space-x-2">
      <.online state={@online} />
      <span>Garden: {@garden.name}</span>
    </div>
    <:actions>
      <.link
        phx-click={JS.push("delete", value: %{id: @garden.id})}
        data-confirm="Are you sure?"
      >
        <.button variant={:danger}>Delete</.button>
      </.link>
    </:actions>
  </.header>

  <div class="mt-8 space-y-10">
    <.detail_field label="Local Sid">{@garden.local_sid}</.detail_field>

    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-200">Seed Generations</h2>
        <div class="flex items-center space-x-2">
          <.link
            patch={~p"/gardens/#{@garden}?generations_filter=current"}
            class={[
              "px-3 py-1 rounded text-sm border",
              @generations_filter == "current" &&
                "bg-zinc-200 text-zinc-800 font-medium",
              @generations_filter != "current" &&
                "bg-zinc-800 text-zinc-200 border-zinc-200 hover:bg-orange-700 hover:text-zinc-50"
            ]}
          >
            Current
          </.link>
          <.link
            patch={~p"/gardens/#{@garden}?generations_filter=all"}
            class={[
              "px-3 py-1 rounded text-sm border",
              @generations_filter == "all" &&
                "bg-zinc-200 text-zinc-800 font-medium",
              @generations_filter != "all" &&
                "bg-zinc-800 text-zinc-200 border-zinc-200 hover:bg-orange-700 hover:text-zinc-50"
            ]}
          >
            All
          </.link>
        </div>
      </div>
      <.table
        id="generations"
        rows={@generations}
        row_click={fn gen -> JS.navigate(~p"/seeds/#{gen.seed.sid}") end}
      >
        <:col :let={gen} label="Seed">{gen.seed.name}</:col>
        <:col :let={gen} label="Profile">{gen.profile.profile_path}</:col>
        <:col :let={gen} label="Gen">{gen.generation_number}</:col>
        <:col :let={gen} label="Current">
          {(gen.is_current && "✓") || ""}
        </:col>
        <:col :let={gen} label="Created" hide_on={:sm}>
          <.local_datetime datetime={gen.created_at_generation} user_timezone={@user_timezone} />
        </:col>
      </.table>
      <p
        :if={@generations == []}
        class="text-sm text-zinc-500 dark:text-zinc-400 italic"
      >
        No seed generations.
      </p>
    </section>

    <section>
      <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-200 mb-4">Subscriptions</h2>
      <.table
        id="subscriptions"
        rows={@garden.subscriptions}
        row_click={
          fn subscription ->
            JS.navigate(~p"/gardens/#{@garden}/subscriptions/#{subscription.sid}")
          end
        }
      >
        <:col :let={subscription} label="Name">{subscription.seed_name}</:col>
        <:col :let={subscription} label="Type">{subscription.seed_type}</:col>
        <:col :let={subscription} label="Updated" hide_on={:sm}>
          <.local_datetime datetime={subscription.updated_at} user_timezone={@user_timezone} />
        </:col>
        <:col :let={subscription} label="">
          <.deploy_button
            subscription_sid={subscription.sid}
            deployable={MapSet.member?(@deployable_subs, subscription.sid)}
            deploying={@deploying_sub == subscription.sid}
            deploy_error={if @deploying_sub == subscription.sid, do: @deploy_error}
          />
        </:col>
      </.table>
      <p
        :if={@garden.subscriptions == []}
        class="text-sm text-zinc-500 dark:text-zinc-400 italic"
      >
        No subscriptions.
      </p>
    </section>

    <section>
      <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-200 mb-4">Deployments</h2>
      <.table
        id="deployments"
        rows={@deployments}
        row_click={fn deployment -> JS.navigate(~p"/deployments/#{deployment.sid}") end}
      >
        <:col :let={deployment} label="">
          <.deployment_status state={deployment.state} result={deployment.result} />
        </:col>
        <:col :let={deployment} label="SID">
          <span
            class="sm:hidden truncate max-sm:max-w-[12rem] inline-block align-bottom"
            title={deployment.sid}
          >
            {deployment.sid}
          </span>
          <span class="hidden sm:inline">{deployment.sid}</span>
        </:col>
        <:col :let={deployment} label="Created" hide_on={:sm}>
          <.local_datetime datetime={deployment.inserted_at} user_timezone={@user_timezone} />
        </:col>
        <:action :let={deployment}>
          <.button
            :if={deployment.state in [:completed, :stale]}
            variant={:secondary}
            type="button"
            phx-click="retry_deployment"
            phx-value-deployment_sid={deployment.sid}
            phx-stop-propagation
            phx-disable-with="Retrying..."
            disabled={@retrying_deployment == deployment.sid}
          >
            Retry
          </.button>
        </:action>
      </.table>
      <p
        :if={@deployments == []}
        class="text-sm text-zinc-500 dark:text-zinc-400 italic"
      >
        No deployments.
      </p>
    </section>
  </div>

  <.modal
    :if={@live_action == :edit}
    id="garden-modal"
    show
    on_cancel={JS.patch(~p"/gardens/#{@garden}")}
  >
    <.live_component
      module={SowerWeb.GardenLive.FormComponent}
      id={@garden.id}
      title={@page_title}
      action={@live_action}
      garden={@garden}
      patch={~p"/gardens/#{@garden}"}
    />
  </.modal>
</Layouts.app>
