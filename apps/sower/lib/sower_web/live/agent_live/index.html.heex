<Layouts.app flash={@flash} current_user={@current_user}>
  <.header>
    Listing Agents
  </.header>

  <.table
    id="agents"
    rows={@streams.agents}
    row_click={fn {_id, agent} -> JS.navigate(~p"/agents/#{agent}") end}
    action_hide_on={:sm}
  >
    <:col :let={{_id, agent}} label="Name">{agent.name}</:col>
    <:col :let={{_id, agent}} label="Online">
      <.online state={agent.sid in Map.keys(@agent_presence)} />
    </:col>
    <:col :let={{_id, agent}} label="Deploy">
      <.result result={agent.latest_deployment && agent.latest_deployment.result} />
    </:col>
    <:action :let={{_id, agent}}>
      <div class="sr-only">
        <.link navigate={~p"/agents/#{agent}"}>Show</.link>
      </div>
    </:action>
    <:action :let={{id, agent}}>
      <.link
        phx-click={JS.push("delete", value: %{id: agent.id}) |> hide("##{id}")}
        data-confirm="Are you sure?"
      >
        Delete
      </.link>
    </:action>
  </.table>

  <.modal
    :if={@live_action in [:new, :edit]}
    id="agent-modal"
    show
    on_cancel={JS.patch(~p"/agents")}
  >
    <.live_component
      module={SowerWeb.AgentLive.FormComponent}
      id={@agent.id || :new}
      title={@page_title}
      action={@live_action}
      agent={@agent}
      patch={~p"/agents"}
    />
  </.modal>
</Layouts.app>
