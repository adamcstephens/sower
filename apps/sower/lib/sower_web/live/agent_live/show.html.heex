<Layouts.app flash={@flash} current_user={@current_user}>
  <.header>
    <div class="flex items-center space-x-2">
      <.online state={@online} />
      <span>Agent: {@agent.name}</span>
    </div>

    <:actions>
      <.link patch={~p"/agents/#{@agent}/show/edit"} phx-click={JS.push_focus()}>
        <.button>Edit agent</.button>
      </.link>
    </:actions>
  </.header>

  <.list>
    <:item title="Local Sid">{@agent.local_sid}</:item>
    <:item title="Seed Generations">
      <div class="flex items-center space-x-2 mb-4">
        <.link
          patch={~p"/agents/#{@agent}?generations_filter=current"}
          class={[
            "px-3 py-1 rounded text-sm border",
            @generations_filter == "current" &&
              "bg-zinc-200 text-zinc-800 font-medium",
            @generations_filter != "current" &&
              "bg-zinc-800 text-zinc-200 border-zinc-200 hover:bg-orange-700 hover:text-zinc-50"
          ]}
        >
          Current
        </.link>
        <.link
          patch={~p"/agents/#{@agent}?generations_filter=all"}
          class={[
            "px-3 py-1 rounded text-sm border",
            @generations_filter == "all" &&
              "bg-zinc-200 text-zinc-800 font-medium",
            @generations_filter != "all" &&
              "bg-zinc-800 text-zinc-200 border-zinc-200 hover:bg-orange-700 hover:text-zinc-50"
          ]}
        >
          All
        </.link>
      </div>
      <.table
        id="generations"
        rows={@generations}
        row_click={fn gen -> JS.navigate(~p"/seeds/#{gen.seed.sid}") end}
      >
        <:col :let={gen} label="Seed">{gen.seed.name}</:col>
        <:col :let={gen} label="Profile">{gen.profile.profile_path}</:col>
        <:col :let={gen} label="Gen">{gen.generation_number}</:col>
        <:col :let={gen} label="Current">
          {(gen.is_current && "✓") || ""}
        </:col>
        <:col :let={gen} label="Created">{gen.created_at_generation}</:col>
      </.table>
    </:item>
    <:item title="Subscriptions">
      <.table
        id="subscriptions"
        rows={@agent.subscriptions}
        row_click={fn subscription -> JS.navigate(~p"/subscriptions/#{subscription.sid}") end}
      >
        <:col :let={subscription}>{subscription.seed_name}</:col>
        <:col :let={subscription}>{subscription.seed_type}</:col>
        <:col :let={subscription}>{subscription.updated_at}</:col>
      </.table>
    </:item>
    <:item title="Deployments">
      <.table
        id="deployments"
        rows={@deployments}
        row_click={fn deployment -> JS.navigate(~p"/deployments/#{deployment.sid}") end}
      >
        <:col :let={deployment} label="Result">
          <.result result={deployment.result} />
        </:col>
        <:col :let={deployment}>{deployment.sid}</:col>
        <:col :let={deployment}>{deployment.inserted_at}</:col>
      </.table>
    </:item>
  </.list>

  <.back navigate={~p"/agents"}>Back to agents</.back>

  <.modal
    :if={@live_action == :edit}
    id="agent-modal"
    show
    on_cancel={JS.patch(~p"/agents/#{@agent}")}
  >
    <.live_component
      module={SowerWeb.AgentLive.FormComponent}
      id={@agent.id}
      title={@page_title}
      action={@live_action}
      agent={@agent}
      patch={~p"/agents/#{@agent}"}
    />
  </.modal>
</Layouts.app>
